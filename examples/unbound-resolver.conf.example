server:
    interface: 127.0.0.1
    port: 53
    do-ip4: yes
    do-ip6: no
    access-control: 127.0.0.0/8 allow
    hide-identity: yes
    hide-version: yes
    prefetch: yes
    qname-minimisation: yes
    rrset-cache-size: 16m
    msg-cache-size: 8m
    cache-max-ttl: 86400
    cache-max-negative-ttl: 3600
    username: "unbound"
